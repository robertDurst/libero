#!/usr/bin/env ruby
# An IRB session with the library booted — our stand-in for `rails console`.
#   DATABASE_URL=postgres://... bin/console
#
# Models are live, e.g. Libero::CalendarEvent.ordered.count. `db` hands you the
# raw connection for ad-hoc SQL, e.g. db.execute("SELECT now()").values
require_relative "../lib/libero"
require "irb"

Libero::DB.connect!

def db = ActiveRecord::Base.connection

puts "Libero #{Libero::VERSION} — ActiveRecord is connected; `db` is the raw connection."
IRB.start
